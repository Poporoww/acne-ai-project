<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/history"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    tools:context=".HistoryActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/pic_history"
            android:layout_width="300dp"
            android:layout_height="200dp"
            android:layout_alignParentTop="true"
            android:layout_marginTop="50dp"
            android:scaleType="fitCenter"
            android:layout_centerHorizontal="true"/>

        <TextView
            android:id="@+id/date_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            android:textColor="@color/black"
            android:textSize="8pt"
            android:layout_marginTop="260dp"
            android:fontFamily="@font/mitr_light"
            android:text="Date"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="310dp"
            android:layout_alignParentStart="true"
            android:textSize="9pt"
            android:layout_marginStart="60dp"
            android:background="#b02dff"
            android:padding="5dp"
            android:textColor="@color/white"
            android:text="ผลลัพธ์"
            android:fontFamily="@font/mitr_light"
            />
        <TextView
            android:id="@+id/result_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="370dp"
            android:textSize="8pt"
            android:textColor="@color/black"
            android:fontFamily="@font/mitr_light"
            android:background="@color/white"
            android:paddingStart="25dp"
            android:padding="8dp"
            tools:ignore="RtlSymmetry" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="450dp"
            android:layout_alignParentStart="true"
            android:textSize="9pt"
            android:layout_marginStart="60dp"
            android:background="#b02dff"
            android:padding="5dp"
            android:textColor="@color/white"
            android:text="คำแนะนำ"
            android:fontFamily="@font/mitr_light"
            />

        <TextView
            android:id="@+id/advice_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="510dp"
            android:textSize="8pt"
            android:background="@color/white"
            android:textColor="@color/black"
            android:padding="8dp"
            android:fontFamily="@font/mitr_light"
            android:paddingStart="25dp"
            tools:ignore="RtlSymmetry" />
    </RelativeLayout>





</ScrollView>
